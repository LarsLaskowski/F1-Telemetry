<Window x:Class="F1ReplayClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:data="clr-namespace:F1ReplayClient.Data"
        xmlns:packets="clr-namespace:F1Server.Core.Enumerations;assembly=F1Server.Core"
        d:DataContext="{d:DesignInstance Type=data:ContextViewData}"
        mc:Ignorable="d"
        Icon="./Images/F1.png"
        Title="F1ReplayClient"
        Height="768"
        Width="1024"
        MaxWidth="1024"
        MinHeight="660"
        MaxHeight="768">
   <Grid Margin="10"
         IsSharedSizeScope="True">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
      </Grid.RowDefinitions> 
      
      <!-- Server information -->
      <Grid Grid.Row="0">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="colStatics"/>
            <ColumnDefinition Width="*"/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0"
                    FontWeight="Medium"
                    Text="Host:"/>
         <TextBox Grid.Column="1"
                  Margin="10,0,0,0"
                  MinHeight="20"
                  IsEnabled="{Binding Path=IsEditable, UpdateSourceTrigger=PropertyChanged}"
                  Text="{Binding Path=Host, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
      </Grid>
      
      <!-- Select folder -->
      <Grid Grid.Row="1"
            Margin="0,10,0,0">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="colStatics"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0"
                    FontWeight="Medium"
                    Text="Path:"/>
         <TextBox Grid.Column="1"
                  MinHeight="20"
                  Margin="10,0,0,0"
                  IsEnabled="{Binding Path=IsEditable, UpdateSourceTrigger=PropertyChanged}"
                  Text="{Binding Path=FilesFolder, UpdateSourceTrigger=PropertyChanged}"/>
         <Button Content="..."
                 IsEnabled="{Binding Path=IsEditable, UpdateSourceTrigger=PropertyChanged}"
                 MinWidth="30"
                 Grid.Column="2"
                 Margin="10,0,0,0"
                 Click="OnButtonClick"/>
      </Grid>
      
      <!-- Options and status -->
      <Grid Grid.Row="2"
            Margin="0,10,0,0">
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
         </Grid.RowDefinitions>
         <Border Grid.Row="0"
                 BorderBrush="CornflowerBlue"
                 Opacity="0.5"
                 BorderThickness="0,1,0,0"/>
         <TextBlock Grid.Row="1"
                    Margin="0,5,0,0"
                    FontWeight="Medium"
                    HorizontalAlignment="Center"
                    Text="{Binding Path=Status, UpdateSourceTrigger=PropertyChanged}"/>
         <Grid Grid.Row="2"
               HorizontalAlignment="Center"
               Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Session id -->
            <Grid Grid.Column="0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Session:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          FontWeight="Medium"
                          Text="{Binding Path=SessionId, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <!-- Session type -->
            <Grid Grid.Column="1" Margin="20,0,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Session type:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          FontWeight="Medium"
                          Text="{Binding Path=SessionType, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <!-- Formula type -->
            <Grid Grid.Column="2" Margin="20,0,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Formula:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          FontWeight="Medium"
                          Text="{Binding Path=FormulaType, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <!-- Track name -->
            <Grid Grid.Column="3" Margin="20,0,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Track name:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          FontWeight="Medium"
                          Text="{Binding Path=TrackName, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <!-- Total laps -->
            <Grid Grid.Column="4" Margin="20,0,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Total laps:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          FontWeight="Medium"
                          Text="{Binding Path=TotalLaps, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <!-- Weather -->
            <Grid Grid.Column="5" Margin="20,0,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Weather:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          FontWeight="Medium"
                          Text="{Binding Path=Weather, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
         </Grid>

         <Border Grid.Row="3"
                 Margin="0,5,0,0"
                 BorderBrush="CornflowerBlue"
                 Opacity="0.3"
                 BorderThickness="0,1,0,0"/>

         <!-- Options -->
         <Grid Grid.Row="4"
               Margin="0,10,0,0">
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Server options -->
            <Grid Grid.Row="0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
               </Grid.ColumnDefinitions>
               <CheckBox Grid.Column="0"
                      Content="Send data to server"
                      IsEnabled="{Binding Path=IsStartable, UpdateSourceTrigger=PropertyChanged}"
                      IsChecked="{Binding Path=SendData, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Column="1"
                      IsEnabled="{Binding Path=SendData, UpdateSourceTrigger=PropertyChanged}"
                      Content="Ignore car packets (Motion, CarSetups...)"
                      IsChecked="{Binding Path=IgnoreCarPackets, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            
            <!-- Packettypes -->
            <Grid Grid.Row="1"
                  Margin="0,5,0,0">
               <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
               </Grid.RowDefinitions>
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                          Margin="0,0,0,5"
                          FontWeight="Medium"
                          Text="Break after sending..."/>
               
               <!-- First row -->
               <CheckBox Grid.Row="1" Grid.Column="0"
                         Content="session packet"
                         IsChecked="{Binding Path=BreakAtSessionPacket, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="1" Grid.Column="1"
                         Content="lap data packet"
                         IsChecked="{Binding Path=BreakAtLapDataPacket, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="1" Grid.Column="2"
                         Content="participants packet"
                         IsChecked="{Binding Path=BreakAtParticipantsPacket, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="1" Grid.Column="3"
                         Content="event packet"
                         IsChecked="{Binding Path=BreakAtEventPacket, UpdateSourceTrigger=PropertyChanged}"/>

               <!-- Second row -->
               <CheckBox Grid.Row="2" Grid.Column="0"
                         Margin="0,5,0,0"
                         Content="car telemetry packet"
                         IsChecked="{Binding Path=BreakAtCarTelemetryPacket, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="2" Grid.Column="1"
                         Margin="0,5,0,0"
                         Content="car telemetry 2 packet"
                         IsChecked="{Binding Path=BreakAtCarTelemetry2Packet, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="2" Grid.Column="2"
                         Margin="0,5,0,0"
                         Content="session history packet"
                         IsChecked="{Binding Path=BreakAtSessionHistoryPacket, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="2" Grid.Column="3"
                         Margin="0,5,0,0"
                         Content="final classification packet"
                         IsChecked="{Binding Path=BreakAtFinalClassificationPacket, UpdateSourceTrigger=PropertyChanged}"/>
               
               <!-- Third row -->
               <CheckBox Grid.Row="3" Grid.Column="0"
                         Margin="0,5,0,0"
                         Content="time trial packet"
                         IsChecked="{Binding Path=BreakAtTimeTrialPacket, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="3" Grid.Column="1"
                         Margin="0,5,0,0"
                         Content="car status packet"
                         IsChecked="{Binding Path=BreakAtCarStatusPacket, UpdateSourceTrigger=PropertyChanged}"/>
               <CheckBox Grid.Row="3" Grid.Column="2"
                         Margin="0,5,0,0"
                         Content="lap positions packet"
                         IsChecked="{Binding Path=BreakAtLapPositionsPacket, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
         </Grid>
      </Grid>

      <!-- Startbutton -->
      <Grid Grid.Row="3" Margin="0,10,0,0">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
         </Grid.ColumnDefinitions>
         <Button Grid.Column="0"
                 Margin="0,0,10,0"
                 MinHeight="24"
                 Click="OnSortClick"
                 IsEnabled="{Binding Path=IsSortable, UpdateSourceTrigger=PropertyChanged}"
                 Content="Sort packets (session time)"/>
         <Button Grid.Column="1"
                 Margin="10,0,0,0"
                 MinHeight="24"
                 Click="OnStartClick"
                 IsEnabled="{Binding Path=IsStartable, UpdateSourceTrigger=PropertyChanged}"
                 Content="Start..."/>
      </Grid>

      <Border Grid.Row="4"
              Margin="0,15,0,15"
              BorderBrush="LightGray"
              BorderThickness="0,1,0,0"/>

      <Grid Grid.Row="5"
            Visibility="{Binding Path=RunFirstVisibility, UpdateSourceTrigger=PropertyChanged}">
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
         </Grid.RowDefinitions>
         <!-- Processed files / total files-->
         <Grid Grid.Row="0"
               Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto" SharedSizeGroup="progressTitle"/>
               <ColumnDefinition Width="*"/>
               <ColumnDefinition Width="Auto" SharedSizeGroup="progressValues"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Files:"/>
            <ProgressBar Grid.Column="1"
                         Margin="10,0,0,0"
                         Height="12"
                         Name="progressFiles"
                         Value="{Binding Path=ProcessedFiles, UpdateSourceTrigger=PropertyChanged}"
                         Maximum="{Binding Path=TotalFiles, UpdateSourceTrigger=PropertyChanged}"/>
            <Grid Grid.Column="2"
                  Margin="10,0,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          VerticalAlignment="Center"
                          Text="{Binding ElementName=progressFiles, Path=Value, UpdateSourceTrigger=PropertyChanged}"/>
               <TextBlock Grid.Column="1"
                          VerticalAlignment="Center"
                          Margin="5,0,0,0"
                          Text="/"/>
               <TextBlock Grid.Column="2"
                          VerticalAlignment="Center"
                          Margin="5,0,0,0"
                          Text="{Binding ElementName=progressFiles, Path=Maximum, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
         </Grid>
         
         <!-- Information -->
         <Grid Grid.Row="1"
               Margin="0,15,0,0">
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
               <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
            </Grid.ColumnDefinitions>
            <!-- Game version -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Game version:"/>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Margin="10,0,0,0"
                       Text="{Binding Path=GameVersion, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Session id -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Margin="0,5,0,0"
                       Text="Session id:"/>
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Margin="10,5,0,0"
                       Text="{Binding Path=SessionId, UpdateSourceTrigger=PropertyChanged}"/>
         </Grid>
         
         <!-- Session packets -->
         <Grid Grid.Row="2"
               Margin="0,15,0,0">
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="*" Name="EventCodes"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="*"/>
               <ColumnDefinition Width="*"/>
               <ColumnDefinition Width="*"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Row 1 -->
            <!-- Unknown -->
            <Grid Grid.Row="0" Grid.Column="0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Unknown:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.Unknown, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            
            <!-- Motion -->
            <Grid Grid.Row="0" Grid.Column="1">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Motion:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.Motion, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Session -->
            <Grid Grid.Row="0" Grid.Column="2">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Session:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.Session}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.Session, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- TimeTrial -->
            <Grid Grid.Row="0" Grid.Column="3">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
              Text="TimeTrial:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.TimeTrial}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
              Margin="10,0,0,0"
              Text="{Binding Path=PacketViewTypes.TimeTrial, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Row 2 -->
            <!-- LapData -->
            <Grid Grid.Row="1" Grid.Column="0"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="LapData:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.LapData}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.LapData, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Event -->
            <Grid Grid.Row="1" Grid.Column="1"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Event:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.Event}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.Event, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Participants -->
            <Grid Grid.Row="1" Grid.Column="2"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="Participants:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.Participants}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.Participants, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- TimeTrial -->
            <Grid Grid.Row="1" Grid.Column="3"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="LapPositions:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.TimeTrial}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.LapPositions, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Row 3 -->
            <!-- CarSetups -->
            <Grid Grid.Row="2" Grid.Column="0"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="CarSetups:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.CarSetups, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- CarTelementry -->
            <Grid Grid.Row="2" Grid.Column="1"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="CarTelemetry:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.CarTelemetry, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- CarStatus -->
            <Grid Grid.Row="2" Grid.Column="2"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="CarStatus:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.CarStatus, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- CarTelemetry2 -->
            <Grid Grid.Row="2" Grid.Column="3"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="CarTelemetry2:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.CarTelemetry2, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Row 4 -->
            <!-- CarDamage -->
            <Grid Grid.Row="3" Grid.Column="0"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="CarDamage:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.CarDamage, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- FinalClassification -->
            <Grid Grid.Row="3" Grid.Column="1"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="FinalClassification:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.FinalClassification}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.FinalClassification, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- LobbyInfo -->
            <Grid Grid.Row="3" Grid.Column="2"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="LobbyInfo:"/>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.LobbyInfo, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Row 5 -->
            <!-- SessionHistory -->
            <Grid Grid.Row="4" Grid.Column="0"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="SessionHistory:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.SessionHistory}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.SessionHistory, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- TyreSets -->
            <Grid Grid.Row="4" Grid.Column="1"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="TyreSets:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.TyreSets}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.TyreSets, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- MotionEx -->
            <Grid Grid.Row="4" Grid.Column="2"
                  Margin="0,10,0,0">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="colTypesLabel"/>
                  <ColumnDefinition Width="*" SharedSizeGroup="colTypesValue"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0"
                          Text="MotionEx:">
                  <TextBlock.Style>
                     <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Style.Triggers>
                           <DataTrigger Binding="{Binding Path=CurrentPacketType}" Value="{x:Static packets:PacketTypes.MotionEx}">
                              <Setter Property="FontWeight" Value="Bold"/>
                           </DataTrigger>
                        </Style.Triggers>
                     </Style>
                  </TextBlock.Style>
               </TextBlock>
               <TextBlock Grid.Column="1"
                          Margin="10,0,0,0"
                          Text="{Binding Path=PacketViewTypes.MotionEx, TargetNullValue=0, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Row EventCodes -->
            <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                  Margin="0,10,0,0">
               <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
               </Grid.RowDefinitions>
               <TextBlock Grid.Row="0"
                          Text="Event codes:"/>
               <ListBox Grid.Row="1"
                     Margin="0,5,0,0"
                     Focusable="False"
                     ItemsSource="{Binding Path=EventCodes, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            
            <!-- Break / Stop buttons -->
            <Grid Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2"
                  Margin="15,0,0,0">
               <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
               </Grid.RowDefinitions>
               <Grid Grid.Row="0"
                     Margin="0,0,0,20"
                     VerticalAlignment="Bottom">
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto" SharedSizeGroup="colTimeStatics"/>
                     <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0"
                             Text="Processing time:"/>
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Margin="10,0,0,0"
                             HorizontalAlignment="Right"
                             Text="{Binding Path=TimeDuration, UpdateSourceTrigger=PropertyChanged}"/>
                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Text="Estimated processing time:"/>
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Margin="10,0,0,0"
                             HorizontalAlignment="Right"
                             Text="{Binding Path=TimeEstimated, UpdateSourceTrigger=PropertyChanged}"/>
               </Grid>
               <Button Grid.Row="1"
                       IsEnabled="{Binding Path=IsPaused, UpdateSourceTrigger=PropertyChanged}"
                       Content="Continue"
                       Click="OnContinueClick"/>
               <Button Grid.Row="2"
                       Margin="0,10,0,0"
                       Content="Stop"
                       IsEnabled="{Binding Path=IsRunning, UpdateSourceTrigger=PropertyChanged}"
                       Click="OnStopClick"/>
            </Grid>
         </Grid>
      </Grid>
   </Grid>
</Window>
